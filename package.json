{
  "name": "pm-textiles-erp",
  "version": "1.0.0",
  "description": "Production, Inventory, and Order Management System for PM Textiles",
  "main": "server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon --config nodemon.json backend/server.js",
    "client": "npm start --prefix frontend",
    "dev:full": "concurrently \"npm run dev\" \"npm run client\"",
    "install:all": "npm install && cd frontend && npm install",
    "build": "cd frontend && npm run build"
  },
  "keywords": [
    "textile",
    "erp",
    "production",
    "inventory",
    "order-management"
  ],
  "author": "PM Textiles Consultancy Team",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.972.0",
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "bwip-js": "^4.8.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-async-handler": "^1.2.0",
    "express-fileupload": "^1.5.2",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "html5-qrcode": "^2.3.8",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.3",
    "moment": "^2.30.1",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "node-schedule": "^2.1.1",
    "nodemailer": "^7.0.12",
    "pdfkit": "^0.17.2",
    "qrcode": "^1.5.4",
    "react-qr-code": "^2.0.18",
    "recharts": "^3.6.0",
    "redis": "^5.10.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  }
}
